{
  "name": "@harborclient/plugin-curl",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "release": "bash scripts/publish.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "pack": "pnpm build && zip -r ../harborclient-plugin-curl.hcp manifest.json README.md dist",
    "sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^1.0.33"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.2",
    "eslint": "^10.6.0",
    "prettier": "^3.9.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
