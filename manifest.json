{
  "id": "com.harborclient.plugins.curl",
  "name": "cURL",
  "author": "HarborClient",
  "version": "1.1.0",
  "summary": "Adds a tab to the request editor that shows an editable `curl` command and can update the request from pasted curl.",
  "description": "README.md",
  "categories": ["requests"],
  "screenshots": ["https://raw.githubusercontent.com/harborclient/plugin-curl/main/screenshot.png"],
  "engines": {
    "harborclient": ">=2.5.6"
  },
  "renderer": "dist/renderer.js",
  "permissions": ["ui"],
  "contributes": {
    "requestTabs": [
      {
        "id": "curl",
        "title": "cURL"
      }
    ]
  }
}
