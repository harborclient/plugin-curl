{
  "id": "com.harborclient.plugins.curl",
  "name": "cURL",
  "author": "HarborClient",
  "version": "1.0.13",
  "summary": "Adds a tab to the request editor that shows an equivalent `curl` command for the configured request.",
  "description": "README.md",
  "categories": [
    "requests"
  ],
  "screenshots": [
    "https://raw.githubusercontent.com/harborclient/plugin-curl/main/screenshot.png"
  ],
  "engines": {
    "harborclient": ">=1.9.0"
  },
  "renderer": "dist/renderer.js",
  "permissions": [
    "ui"
  ],
  "contributes": {
    "requestTabs": [
      {
        "id": "curl",
        "title": "cURL"
      }
    ]
  }
}
